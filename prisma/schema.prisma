generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id               String            @id @default(cuid())
  externalId       String?           @unique
  email            String            @unique
  phone            String?
  firstName        String?
  lastName         String?
  createdAt        DateTime          @default(now())
  totalOrders      Int               @default(0)
  totalSpent       Float             @default(0)
  avgOrderValue    Float             @default(0)
  lastOrderDate    DateTime?
  firstOrderDate   DateTime?
  recencyScore     Int?
  frequencyScore   Int?
  monetaryScore    Int?
  segment          String?
  churnRiskScore   Int?
  orders           Order[]
  events           CustomerEvent[]
  campaignReceipts CampaignReceipt[]
}

model Order {
  id          String    @id @default(cuid())
  externalId  String?   @unique
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  orderNumber String
  totalAmount Float
  status      String
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  items       OrderItem[]

  @@index([customerId, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@index([orderId])
  @@index([productId])
}

model Product {
  id                   String      @id @default(cuid())
  externalId           String?     @unique
  name                 String
  sku                  String      @unique
  price                Float
  category             String?
  imageUrl             String?
  avgReplenishmentDays Int?
  orderItems           OrderItem[]
}

model CustomerEvent {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  eventType  String
  properties Json?
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([eventType, createdAt])
}

model Campaign {
  id          String            @id @default(cuid())
  name        String
  type        String
  channel     String
  status      String
  createdAt   DateTime          @default(now())
  flowConfig  Json?
  subject     String?
  body        String?
  scheduledAt DateTime?
  sentAt      DateTime?
  receipts    CampaignReceipt[]
  metrics     CampaignMetrics?
}

model CampaignReceipt {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel     String
  status      String
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  convertedAt DateTime?
  revenue     Float?

  @@index([campaignId, status])
  @@index([customerId])
}

model CampaignMetrics {
  id           String   @id @default(cuid())
  campaignId   String   @unique
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sent         Int      @default(0)
  delivered    Int      @default(0)
  opened       Int      @default(0)
  clicked      Int      @default(0)
  converted    Int      @default(0)
  revenue      Float    @default(0)
  unsubscribed Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String
  type      String
  subject   String?
  body      String
  createdAt DateTime @default(now())
}

model IntegrationState {
  id                       String   @id @default(cuid())
  provider                 String   @unique
  connected                Boolean  @default(false)
  accessToken              String?
  refreshToken             String?
  tokenExpiresAt           DateTime?
  lastSyncAt               DateTime?
  lastSyncStatus           String?
  lastSyncMessage          String?
  syncInProgress           Boolean  @default(false)
  shopifyLastOrdersSyncAt  DateTime?
  shopifyLastProductsSyncAt DateTime?
  shopifyLastCustomersSyncAt DateTime?
  shopifyLastRunId         String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ShopifySyncRun {
  id                 String   @id @default(cuid())
  mode               String
  status             String
  triggeredBy        String?
  isBackground       Boolean  @default(false)
  startedAt          DateTime?
  completedAt        DateTime?
  sinceOrdersAt      DateTime?
  sinceProductsAt    DateTime?
  customersFetched   Int      @default(0)
  productsFetched    Int      @default(0)
  ordersFetched      Int      @default(0)
  customersUpserted  Int      @default(0)
  productsUpserted   Int      @default(0)
  ordersUpserted     Int      @default(0)
  warnings           Json?
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
}

model BrandProfile {
  id          String   @id @default(cuid())
  storeId     String   @unique @default("default")

  // Core Identity
  brandName        String?
  tagline          String?
  industry         String?
  niche            String?
  brandStory       String?
  usp              String?
  missionStatement String?
  websiteUrl       String?

  // Legacy compatibility fields
  industryVertical String?
  pricePositioning String?
  foundedYear      Int?
  coreValues       String[] @default([])
  shopifyStoreUrl  String?

  // Target Audience
  targetDemographics   String?
  targetPsychographics String?
  audiencePainPoints   String?
  audienceDesires      String?

  // Voice & Tone — 10 preset dimensions (0-100)
  voiceFormalCasual               Int @default(50)
  voiceSeriousPlayful             Int @default(50)
  voiceReservedEnthusiastic       Int @default(50)
  voiceTechnicalSimple            Int @default(50)
  voiceAuthoritativeApproachable  Int @default(50)
  voiceMinimalDescriptive         Int @default(50)
  voiceLuxuryAccessible           Int @default(50)
  voiceEdgySafe                   Int @default(50)
  voiceEmotionalRational          Int @default(50)
  voiceTrendyTimeless             Int @default(50)

  voiceDescription String?

  // Email Preferences
  greetingStyle       String? @default("friendly")
  signOffStyle        String? @default("warm")
  emojiUsage          String? @default("sparingly")
  preferredLength     String? @default("medium")
  discountPhilosophy  String? @default("strategically")

  // Analysis and related entities
  lastStoreAnalysis    DateTime?
  storeAnalysisData    Json?
  voiceTone            VoiceTone?
  dosAndDonts          DosAndDonts?
  productIntelligence  ProductIntelligence?
  compliance           Compliance?
  seasonalContext      SeasonalContext?
  personas             Persona[]
  sellingPoints        SellingPoint[]
  documents            BrandDocument[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CustomVoiceDimension {
  id          String   @id @default(cuid())
  storeId     String
  leftLabel   String
  rightLabel  String
  description String?
  value       Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, createdAt])
}

model BrandCTA {
  id          String   @id @default(cuid())
  storeId     String
  text        String
  isPreferred Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([storeId, createdAt])
}

model BrandPhrase {
  id          String   @id @default(cuid())
  storeId     String
  phrase      String
  type        String
  createdAt   DateTime @default(now())

  @@index([storeId, type, createdAt])
}

model BrandRule {
  id          String   @id @default(cuid())
  storeId     String
  rule        String
  type        String
  priority    String   @default("important")
  createdAt   DateTime @default(now())

  @@index([storeId, type, priority, createdAt])
}

model BrandProfileMeta {
  id      String @id @default(cuid())
  storeId String @unique
}

model Persona {
  id                String       @id @default(cuid())
  brandProfileId    String
  brandProfile      BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  name              String
  isPrimary         Boolean      @default(false)
  ageRange          String?
  genderSkew        String?
  locationPatterns  String[]
  incomeLevel       String?
  lifestyle         String[]
  values            String[]
  interests         String[]
  painPoints        String[]
  motivations       String[]
  objections        String[]
  languageTheyUse   String[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([brandProfileId, createdAt])
}

model SellingPoint {
  id              String       @id @default(cuid())
  brandProfileId  String
  brandProfile    BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  type            String
  title           String
  description     String?
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())

  @@index([brandProfileId, type, sortOrder])
}

model VoiceTone {
  id                    String       @id @default(cuid())
  brandProfileId        String       @unique
  brandProfile          BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  formalCasual          Int          @default(5)
  seriousPlayful        Int          @default(5)
  reservedEnthusiastic  Int          @default(5)
  technicalSimple       Int          @default(5)
  traditionalEdgy       Int          @default(5)
  corporatePersonal     Int          @default(5)
  welcomeTone           Json?
  promotionalTone       Json?
  educationalTone       Json?
  vipTone               Json?
  winbackTone           Json?
  transactionalTone     Json?
  apologyTone           Json?
  launchTone            Json?
  sentenceLength        String?
  paragraphLength       String?
  useContractions       String?
  useExclamations       String?
  emojiUsage            Json?
  useCaps               String?
  preferredAdjectives   String[]
  preferredVerbs        String[]
  preferredCTAs         String[]
  signaturePhrases      String[]
  greetingStyle         String?
  signoffStyle          String?
  customerReference     String?
  brandReference        String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model DosAndDonts {
  id                String       @id @default(cuid())
  brandProfileId    String       @unique
  brandProfile      BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  messagingDos      Json?
  languageDos       Json?
  complianceDos     Json?
  designDos         Json?
  timingDos         Json?
  messagingDonts    Json?
  languageDonts     Json?
  complianceDonts   Json?
  designDonts       Json?
  toneDonts         Json?
  cautionRules      Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model ProductIntelligence {
  id                 String       @id @default(cuid())
  brandProfileId     String       @unique
  brandProfile       BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  descriptionStyle   String?
  priceMentionRule   String?
  products           Json?
  collections        Json?
  heroProducts       String[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Compliance {
  id                     String       @id @default(cuid())
  brandProfileId         String       @unique
  brandProfile           BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  physicalAddress        String?
  unsubscribeText        String?
  smsOptOutText          String?
  privacyPolicyUrl       String?
  termsUrl               String?
  fdaDisclaimer          String?
  prop65Warning          String?
  subscriptionDisclosure String?
  autoRenewalLanguage    String?
  customDisclaimers      String[]
  trademarkRules         String?
  ugcRightsText          String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model SeasonalContext {
  id                  String       @id @default(cuid())
  brandProfileId      String       @unique
  brandProfile        BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  celebratedHolidays  String[]
  skippedHolidays     String[]
  brandAnniversary    DateTime?
  plannedSales        Json?
  blackoutDates       DateTime[]
  blackoutTopics      Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model BrandDocument {
  id                String       @id @default(cuid())
  brandProfileId    String
  brandProfile      BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  fileName          String
  fileType          String
  fileUrl           String
  fileSize          Int
  documentType      String?
  extractedText     String?
  extractedRules    Json?
  extractionStatus  String       @default("pending")
  extractedAt       DateTime?
  appliedToBrand    Boolean      @default(false)
  conflictsFound    Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([brandProfileId, createdAt])
}

model StoreScreenshot {
  id                String   @id @default(cuid())
  brandProfileId    String
  pageType          String
  pageUrl           String
  screenshotUrl     String
  extractedElements Json?
  capturedAt        DateTime @default(now())

  @@index([brandProfileId, capturedAt])
}
